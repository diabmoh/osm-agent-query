{
  "name": "osm-agent-query",
  "version": "0.1.0",
  "description": "Structured OpenStreetMap access for AI coding agents via MCP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "osm-agent-query": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "eval": "tsx eval/run.ts",
    "eval:dry": "tsx eval/run.ts --dry-run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "openstreetmap",
    "osm",
    "geospatial",
    "agents",
    "codex",
    "cursor"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/diabmoh/osm-agent-query.git"
  }
}
